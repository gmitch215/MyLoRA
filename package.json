{
  "private": true,
  "name": "mylora",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "bunx nuxi dev --no-restart --public --port 8787",
    "dev:test": "NODE_OPTIONS='--max-old-space-size=8192' bunx nuxi dev --no-restart --public --port 8787 --dotenv .config/test.env",
    "dev:setup": "rm -rf .data-setup && NUXT_IGNORE_LOCK=1 NUXT_BUILD_DIR=.nuxt-setup NUXT_VITE_CACHE=node_modules/.cache/vite-setup NODE_OPTIONS='--max-old-space-size=4096' bunx nuxi dev --no-restart --public --port 8788 --dotenv .config/setup.env",
    "dev:cloudflare": "bun run build && wrangler dev --local --port 8787",
    "build": "NODE_OPTIONS='--max-old-space-size=4096' nuxt build",
    "build:e2e": "MYLORA_E2E_BUILD=1 MYLORA_MOCK_CF=1 NODE_OPTIONS='--max-old-space-size=4096' nuxt build",
    "preview:e2e": "NODE_ENV=test PORT=8787 NITRO_PORT=8787 NODE_V8_COVERAGE=.coverage/server-raw node --env-file=.config/test.env tests/e2e/preview-e2e.mjs",
    "postinstall": "nuxt prepare",
    "prettier": "bunx prettier --write .",
    "prettier:check": "bunx prettier --check .",
    "test:unit": "NODE_OPTIONS='--max-old-space-size=8192' vitest run",
    "test:unit:coverage": "NODE_OPTIONS='--max-old-space-size=8192' vitest run --coverage",
    "coverage:server": "sh tests/e2e/server-coverage.sh",
    "test": "NODE_OPTIONS='--max-old-space-size=4096' bunx playwright test && bun run test:setup",
    "test:main": "NODE_OPTIONS='--max-old-space-size=4096' bunx playwright test",
    "test:setup": "PLAYWRIGHT_SETUP=1 NODE_OPTIONS='--max-old-space-size=4096' bunx playwright test",
    "test:headed": "NODE_OPTIONS='--max-old-space-size=4096' bunx playwright test --headed",
    "test:coverage": "bun run build:e2e && rm -rf .coverage/server-raw coverage/server && COVERAGE=1 NODE_OPTIONS='--max-old-space-size=4096' bunx playwright test; code=$?; bun run coverage:server; exit $code",
    "test:report": "NODE_OPTIONS='--max-old-space-size=4096' bunx playwright show-report",
    "prepare": "husky install"
  },
  "peerDependencies": {
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@cloudflare/workers-types": "^4.20260630.1",
    "@libsql/client": "^0.17.4",
    "@nuxt/icon": "^2.2.5",
    "@nuxt/image": "^2.0.0",
    "@nuxt/kit": "^4.4.8",
    "@nuxt/ui": "^4.9.0",
    "@nuxthub/core": "^0.10.7",
    "@nuxtjs/robots": "^6.1.2",
    "@nuxtjs/sitemap": "^8.2.2",
    "@pinia/nuxt": "^0.11.3",
    "@types/luxon": "^3.7.2",
    "@unovis/ts": "^1.6.7",
    "@unovis/vue": "^1.6.7",
    "@vueuse/core": "^14.3.0",
    "@vueuse/nuxt": "^14.3.0",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2",
    "edgeport": "^1.0.2",
    "highlight.js": "^11.11.1",
    "luxon": "^3.7.2",
    "marked": "^18.0.0",
    "nuxt": "^4.4.8",
    "nuxt-auth-utils": "^0.5.29",
    "nuxt-schema-org": "^6.2.3",
    "nuxt-viewport": "^2.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@codecov/nuxt-plugin": "^2.0.1",
    "@iconify-json/cib": "^1.2.3",
    "@iconify-json/lucide": "^1.2.115",
    "@iconify-json/material-symbols": "^1.2.81",
    "@iconify-json/mdi": "^1.2.3",
    "@nuxt/hints": "^1.1.3",
    "@nuxt/test-utils": "^4.0.3",
    "@nuxtjs/google-fonts": "^3.2.0",
    "@playwright/test": "^1.61.1",
    "@types/bun": "^1.3.14",
    "@vitest/coverage-v8": "^4.1.9",
    "@vue/test-utils": "^2.4.11",
    "c8": "^11.0.0",
    "happy-dom": "^20.10.6",
    "husky": "^9.1.7",
    "lightningcss": "^1.32.0",
    "lint-staged": "^17.0.8",
    "monocart-reporter": "^2.12.1",
    "prettier": "^3.9.4",
    "prettier-plugin-organize-imports": "^4.3.0",
    "prettier-plugin-sh": "^0.18.1",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "sass": "^1.101.0",
    "v8-to-istanbul": "^9.3.0",
    "vitest": "^4.1.9",
    "vue-tsc": "^3.3.5",
    "wrangler": "^4.105.0"
  },
  "lint-staged": {
    "*.{ts,js,mjs,cjs,vue,css,scss,md,sh,yml}": "prettier --write"
  }
}
