{
  "private": true,
  "name": "mylora",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "bunx nuxi dev --no-restart --public --port 8787",
    "dev:test": "NODE_OPTIONS='--max-old-space-size=8192' bunx nuxi dev --no-restart --public --port 8787 --dotenv .config/test.env",
    "dev:cloudflare": "bun run build && wrangler dev --local --port 8787",
    "build": "NODE_OPTIONS='--max-old-space-size=4096' nuxt build",
    "postinstall": "nuxt prepare",
    "prettier": "bunx prettier --write .",
    "prettier:check": "bunx prettier --check .",
    "test": "NODE_OPTIONS='--max-old-space-size=4096' bunx playwright test",
    "test:headed": "NODE_OPTIONS='--max-old-space-size=4096' bunx playwright test --headed",
    "test:coverage": "COVERAGE=1 NODE_OPTIONS='--max-old-space-size=4096' bunx playwright test",
    "test:report": "NODE_OPTIONS='--max-old-space-size=4096' bunx playwright show-report",
    "prepare": "husky install"
  },
  "peerDependencies": {
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@cloudflare/workers-types": "^4.20260626.1",
    "@libsql/client": "^0.17.4",
    "@nuxt/icon": "^2.2.4",
    "@nuxt/image": "^2.0.0",
    "@nuxt/kit": "^4.4.8",
    "@nuxt/ui": "^4.9.0",
    "@nuxthub/core": "^0.10.7",
    "@nuxtjs/robots": "^6.1.1",
    "@nuxtjs/sitemap": "^8.2.1",
    "@pinia/nuxt": "^0.11.3",
    "@types/luxon": "^3.7.2",
    "@unovis/ts": "^1.6.6",
    "@unovis/vue": "^1.6.6",
    "@vueuse/core": "^14.3.0",
    "@vueuse/nuxt": "^14.3.0",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2",
    "highlight.js": "^11.11.1",
    "luxon": "^3.7.2",
    "marked": "^16.4.1",
    "nuxt": "^4.4.8",
    "nuxt-auth-utils": "^0.5.29",
    "nuxt-schema-org": "^6.2.2",
    "nuxt-viewport": "^2.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@codecov/nuxt-plugin": "^2.0.1",
    "@iconify-json/cib": "^1.2.3",
    "@iconify-json/lucide": "^1.2.114",
    "@iconify-json/material-symbols": "^1.2.81",
    "@iconify-json/mdi": "^1.2.3",
    "@nuxt/hints": "^1.1.3",
    "@nuxtjs/google-fonts": "^3.2.0",
    "@playwright/test": "^1.61.1",
    "@types/bun": "^1.3.14",
    "husky": "^9.1.7",
    "lightningcss": "^1.32.0",
    "lint-staged": "^17.0.8",
    "monocart-reporter": "^2.12.0",
    "prettier": "^3.8.4",
    "prettier-plugin-organize-imports": "^4.3.0",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "sass": "^1.101.0",
    "vue-tsc": "^3.3.5",
    "wrangler": "^4.105.0"
  },
  "lint-staged": {
    "*.{ts,js,vue,css,scss,md}": "prettier --write"
  }
}
